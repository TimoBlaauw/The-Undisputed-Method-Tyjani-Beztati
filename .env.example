# GHL (GoHighLevel) credentials — get from Floris
# These are SERVER-ONLY. Never expose them client-side.

GHL_API_KEY=your-private-integration-token-here
GHL_LOCATION_ID=your-ghl-location-id-here
GHL_CALENDAR_ID=your-ghl-calendar-id-here

# Optional: override the GHL API base URL
# GHL_API_BASE=https://services.leadconnectorhq.com
